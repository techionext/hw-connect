{
  "name": "api-template",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "rimraf dist && tsup src",
    "dev": "tsx watch src/index.ts",
    "prepare": "husky",
    "create:u": "tsx scripts/create-use-case.ts",
    "create:r": "tsx scripts/generate-repository.ts",
    "validate": "cross-env NODE_OPTIONS=--max-old-space-size=12096 npm-run-all swagger:fix swagger:import swagger:schema validate:biome validate:tsc",
    "validate:biome": "biome format . --write && biome check . --fix",
    "validate:tsc": "cross-env NODE_OPTIONS=--max-old-space-size=12096 tsc --noEmit",
    "swagger:import": "tsx src/Config/Swagger/CreateImports.ts",
    "swagger:schema": "tsx src/Config/Swagger/CreateResponseSchema.ts",
    "swagger:fix": "tsx src/Config/Swagger/FixResponseType.ts"
  },
  "keywords": [],
  "author": "josevictorm",
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@prisma/client": "^6.16.2",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "cross-env": "^10.0.0",
    "csv-parse": "^6.1.0",
    "csv-writer": "^1.6.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "file-type": "^21.0.0",
    "glob": "^11.0.3",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^25.5.2",
    "i18next-fs-backend": "^2.6.0",
    "i18next-http-middleware": "^3.8.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "2.0.2",
    "multer-s3": "^3.0.1",
    "node-cron": "^4.2.1",
    "nodemailer": "6.4.17",
    "npm-run-all": "^4.1.5",
    "openapi-types": "^12.1.3",
    "otplib": "^12.0.1",
    "pino": "^9.11.0",
    "pino-pretty": "^13.1.1",
    "prisma": "^6.16.2",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "swagger-ui-express": "^5.0.1",
    "ts-morph": "^26.0.0",
    "ts-to-zod": "^3.15.0",
    "tsyringe": "^4.10.0",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@faker-js/faker": "^9.9.0",
    "@tsconfig/node-ts": "^23.6.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/multer-s3": "^3.0.3",
    "@types/node": "^24.5.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/xlsx": "^0.0.36",
    "husky": "^9.1.7",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
